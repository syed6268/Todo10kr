# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# Vector store
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=milestone_kb

# Web search
# Set true + provide BRAVE_API_KEY to enable live search.
# Otherwise data/fixtures/web_search_fixtures.json is used.
USE_LIVE_SEARCH=false
BRAVE_API_KEY=

# Agent limits
MAX_AGENT_STEPS=8
MAX_FETCH_BYTES=200000
FETCH_TIMEOUT_SECONDS=10

# API server
API_HOST=0.0.0.0
API_PORT=8001
